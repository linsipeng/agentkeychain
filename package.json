{
  "name": "agentkeychain",
  "version": "0.1.0",
  "description": "Agent-native zero-knowledge credential vault. CLI + MCP Server.",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "agentkeychain": "./bin/agentkeychain"
  },
  "scripts": {
    "dev": "bun run src/cli/index.ts",
    "test": "bun test",
    "lint": "eslint src tests",
    "build": "bun build src/cli/index.ts --compile --outfile bin/agentkeychain-bin",
    "typecheck": "tsc --noEmit"
